CRM_SECRET_KEY=change-this-long-random-secret
FLASK_DEBUG=0
PORT=5000

# ----------------------------- PostgreSQL -----------------------------
# Option A: one connection string (takes priority if set).
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/logistics_crm

# Option B: individual settings (used when DATABASE_URL is empty).
PGHOST=localhost
PGPORT=5432
PGDATABASE=logistics_crm
PGUSER=postgres
PGPASSWORD=postgres
